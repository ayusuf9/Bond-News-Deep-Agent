# --- Required ---
# Google Gemini API key (https://aistudio.google.com/app/apikey)
GOOGLE_API_KEY=your-google-api-key-here

# Tavily search API key (https://app.tavily.com/)
TAVILY_API_KEY=your-tavily-api-key-here

# --- Optional (sensible defaults) ---
# LangChain provider:model identifier resolved by deepagents.
# Examples: google_genai:gemini-2.5-flash, google_genai:gemini-2.5-pro,
#           google_genai:gemini-3.5-flash, google_genai:gemini-3.5-pro
# BOND_NEWS_MODEL_NAME=google_genai:gemini-2.5-pro

# Default search budget per tool call (1-20)
# BOND_NEWS_MAX_SEARCH_RESULTS=8

# Default Tavily news recency window in days (1-30)
# BOND_NEWS_DEFAULT_DAYS_BACK=7

# Where final markdown reports are written (created if missing)
# BOND_NEWS_REPORTS_DIR=reports

# Recursion limit for the deep agent state graph
# BOND_NEWS_RECURSION_LIMIT=100

# Logging level: DEBUG | INFO | WARNING | ERROR
# BOND_NEWS_LOG_LEVEL=INFO
